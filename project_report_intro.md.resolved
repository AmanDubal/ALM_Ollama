### 4.4.6 Response Parser — Handling `>` Separators

```python
# Normalise arrow-separated one-liner output into newlines
# e.g. "Location: Home> ACTIVITY: Crying baby> ..."
text = re.sub(r'\s*>\s*', '\n', response_text.strip())

def extract(label: str, default: str = '') -> str:
    """Extract a section value, stopping at the next section header."""
    stop = '|'.join(re.escape(k) for k in _SECTION_KEYS)
    pattern = (
        rf'(?:^[^\S\r\n]*(?:[^\w\r\n]*)?{re.escape(label)}[^\:\n]*:\s*)'
        rf'(.+?)'
        rf'(?=\n[^\S\r\n]*(?:[^\w\r\n]*)?(?:{stop})[^\:\n]*:|\Z)'
    )
    match = re.search(pattern, text, re.IGNORECASE | re.MULTILINE | re.DOTALL)
    return match.group(1).strip() if match else default
```

