## 4.4 Coding

This section presents the key code segments from each module, annotated for clarity.

---

### 4.4.1 Audio Preprocessing (`modules/preprocessing/`)

```python
def load_audio(self, file_path: str) -> Tuple[np.ndarray, int]:
    """Load and normalise audio to mono 16 kHz."""
    audio, sr = librosa.load(file_path, sr=16000, mono=True)
    # Amplitude normalisation — prevents clipping in downstream models
    if np.max(np.abs(audio)) > 0:
        audio = audio / np.max(np.abs(audio))
    return audio, sr
```

---

### 4.4.2 Speech Recognition (`modules/speech/`)

```python
def transcribe(self, audio: np.ndarray, sr: int) -> Dict[str, Any]:
    """Transcribe audio using OpenAI Whisper."""
    result = self.model.transcribe(
        audio,
        language=None,       # auto-detect
        temperature=0.0,     # deterministic output
        fp16=False
    )
    return {
        'text':     result.get('text', '').strip(),
        'language': result.get('language', 'unknown')
    }
```

---

### 4.4.3 Sound Event Detection (`modules/sound_detection/`)

```python
def detect(self, audio: np.ndarray, sr: int) -> Dict[str, Any]:
    """Run YAMNet and return top sound events above threshold."""
    waveform = tf.constant(audio, dtype=tf.float32)
    scores, _, _ = self.model(waveform)
    mean_scores = tf.reduce_mean(scores, axis=0).numpy()

    top_indices = np.argsort(mean_scores)[::-1][:5]
    events = [
        self.class_names[i]
        for i in top_indices
        if mean_scores[i] >= self.confidence_threshold
    ]
    return {'events': events, 'primary_event': events[0] if events else None}
```

---

### 4.4.4 Semantic Risk Analysis (`modules/context/semantic_analyzer.py`)

```python
def _compute_risk_score(self, emergency, injury, conflict,
                         medical, guidance, vulnerability) -> float:
    """Weighted risk scoring — capped at 1.0."""
    score = 0.0
    score += min(len(emergency) * 0.30, 0.60)   # emergency keywords
    score += min(len(injury)    * 0.25, 0.50)   # injury indicators
    score += min(len(medical)   * 0.20, 0.40)   # medical keywords
    score += min(len(conflict)  * 0.20, 0.40)   # conflict signals
    score += min(len(guidance)  * 0.15, 0.30)   # dispatch phrases
    score += min(len(vulnerability) * 0.10, 0.20)
    return min(score, 1.0)
```

---

